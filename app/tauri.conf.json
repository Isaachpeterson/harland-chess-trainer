{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Harland Chess Trainer",
  "version": "0.1.0",
  "identifier": "com.harland.chesstrainer",
  "build": {
    "beforeDevCommand": "cd ../src-ui && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd ../src-ui && npm run build",
    "frontendDist": "../src-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Harland Chess Trainer",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../resources/stockfish/*": "stockfish/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Turn your Lichess blunders into training puzzles",
    "longDescription": "Harland Chess Trainer analyzes your Lichess games, detects blunders, and generates targeted puzzles so you can train on the patterns you actually miss.",
    "homepage": "https://github.com/Isaachpeterson/harland-chess-trainer",
    "license": "GPL-3.0",
    "licenseFile": "../LICENSE",
    "copyright": "Copyright (C) 2026 Isaac Peterson"
  }
}
